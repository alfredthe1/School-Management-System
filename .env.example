# Environment: development (default) | production
DJANGO_ENV=development

# Django core
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Mobile testing (development)
# NGROK_URL=https://your-subdomain.ngrok-free.app
# LAN_HOST=192.168.1.100

# Database (production — use docker compose up -d for local Postgres)
DJANGO_DB_ENGINE=postgresql
POSTGRES_DB=happy_child_school
POSTGRES_USER=happy_child
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
POSTGRES_SSLMODE=prefer

# Optional Redis cache (multi-worker production)
# REDIS_URL=redis://127.0.0.1:6379/0

# Production HTTPS (when DJANGO_ENV=production)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
USE_X_FORWARDED_HOST=True
ENABLE_PROXY_MIDDLEWARE=False
LOG_LEVEL=INFO

# Gunicorn (optional overrides)
# GUNICORN_BIND=127.0.0.1:8000
# GUNICORN_WORKERS=3

# Mobile money — set True when ready (simulation auto-enables without API keys)
MOBILE_MONEY_ENABLED=True
MOBILE_MONEY_MIN_AMOUNT=500
MOBILE_MONEY_MAX_AMOUNT=10000000
MOBILE_MONEY_POLL_SECONDS=3

# Webhook security (required in production)
MOBILE_MONEY_CALLBACK_SECRET=your-shared-callback-secret
MOBILE_MONEY_CALLBACK_HEADER=X-Callback-Secret
MOBILE_MONEY_CALLBACK_IP_ALLOWLIST=

# MTN MoMo Uganda (sandbox URLs shown — switch to live when approved)
MTN_MOMO_ENV=sandbox
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_CURRENCY=UGX
MTN_MOMO_CALLBACK_URL=https://yourdomain.com/parents/mobile-money/mtn/callback/
MTN_MOMO_TOKEN_URL=https://sandbox.momodeveloper.mtn.com/collection/token/
MTN_MOMO_REQUEST_URL=https://sandbox.momodeveloper.mtn.com/collection/v1_0/requesttopay

# Airtel Money Uganda
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_CLIENT_SECRET=
AIRTEL_MONEY_CURRENCY=UGX
AIRTEL_MONEY_CALLBACK_URL=https://yourdomain.com/parents/mobile-money/airtel/callback/
AIRTEL_MONEY_TOKEN_URL=https://openapiuat.airtel.africa/auth/oauth2/token
AIRTEL_MONEY_COLLECT_URL=https://openapiuat.airtel.africa/merchant/v1/payments/

# SMS (Twilio — optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Happy Child Nursery and Primary School <noreply@happychild.ug>